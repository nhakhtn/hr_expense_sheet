<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit hr.expense list view to show sheet_id -->
    <record id="view_hr_expense_list_inherit_sheet" model="ir.ui.view">
        <field name="name">hr.expense.list.inherit.sheet</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_expenses_analysis_tree"/>
        <field name="arch" type="xml">
            <!-- Add sheet_id column after employee_id -->
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="sheet_id" optional="show"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
