<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action Window -->
    <record id="action_hr_expense_sheet" model="ir.actions.act_window">
        <field name="name">Expense Sheets</field>
        <field name="res_model">hr.expense.sheet</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first expense sheet
            </p>
            <p>
                Group multiple expenses together and submit them for approval in one click.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <record id="menu_hr_expense_sheet" model="ir.ui.menu">
        <field name="name">Expense Sheets</field>
        <field name="parent_id" ref="hr_expense.menu_hr_expense_root"/>
        <field name="action" ref="action_hr_expense_sheet"/>
        <field name="sequence">15</field>
    </record>

    <!-- Tree View -->
    <record id="view_hr_expense_sheet_tree" model="ir.ui.view">
        <field name="name">hr.expense.sheet.tree</field>
        <field name="model">hr.expense.sheet</field>
        <field name="arch" type="xml">
            <list string="Expense Sheets" decoration-success="state=='approved'" decoration-info="state=='submitted'" decoration-danger="state=='refused'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="expense_count" string="# Expenses"/>
                <field name="amount_total" sum="Total"/>
                <field name="state" widget="badge" decoration-success="state in ('approved','posted','paid')" decoration-info="state=='submitted'" decoration-danger="state=='refused'"/>
                <field name="date_submit" optional="hide"/>
                <field name="date_approve" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_expense_sheet_form" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form</field>
        <field name="model">hr.expense.sheet</field>
        <field name="arch" type="xml">
            <form string="Expense Sheet">
                <header>
                    <!-- Draft state buttons - for owner -->
                    <button name="button_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="button_delete" string="Delete" type="object" invisible="state not in ('draft', 'submitted')"/>
                    <!-- Approve/Refuse buttons - hide for owner -->
                    <button name="button_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted' or is_owner"/>
                    <button name="button_refuse" string="Refuse" type="object" invisible="state != 'submitted' or is_owner"/>
                    <!-- Accountant buttons -->
                    <button name="button_post" string="Post Journal" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                    <button name="button_pay" string="Register Payment" type="object" class="oe_highlight" invisible="state != 'posted'"/>
                    <button name="button_reset_draft" string="Reset to Draft" type="object" invisible="state not in ('refused', 'approved', 'posted', 'paid')"/>
                    <!-- View buttons -->
                    <button name="action_view_expenses" string="View Expenses" type="object" invisible="expense_count == 0" class="oe_link"/>
                    <button name="action_view_journal_entry" string="View Journal Entry" type="object" invisible="not account_move_id" class="oe_link"/>
                    <button name="action_view_payment" string="View Payment" type="object" invisible="not account_payment_id" class="oe_link"/>
                    <!-- Status bar -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,posted,paid"/>
                </header>
                <sheet edit="can_edit">
                    <!-- Header -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Expenses March 2026"/>
                        </h1>
                    </div>
                    <!-- Main content -->
                    <group>
                        <group>
                            <field name="employee_id" options="{'no_create': True, 'no_open': True}" readonly="True"/>
                            <field name="department_id" options="{'no_open': True}" readonly="True"/>
                            <field name="manager_id" options="{'no_create': True, 'no_open': True}" readonly="True"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                        <group>
                            <field name="amount_total" string="Total Amount"/>
                            <field name="expense_count" string="# Expenses"/>
                            <field name="date_submit"/>
                            <field name="date_approve"/>
                            <field name="date_post"/>
                            <field name="date_paid"/>
                        </group>
                    </group>
                    <!-- Notebook with expenses -->
                    <notebook>
                        <page string="Expenses" name="expenses">
                            <field name="expense_ids" context="{'default_employee_id': employee_id}">
                                <list string="Expenses" decoration-success="state=='approved'" decoration-info="state=='submitted'">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="total_amount" sum="Total"/>
                                    <field name="tax_ids" widget="many2many_tags"/>
                                    <field name="payment_mode"/>
                                    <field name="state" widget="badge"/>
                                    <button name="action_remove_from_sheet" string="Refuse" type="object" invisible="is_owner or parent.state != 'submitted'"/>
                                </list>
                                <form string="Expense">
                                    <group>
                                        <group>
                                            <field name="name"/>
                                            <field name="date"/>
                                            <field name="product_id"/>
                                            <field name="quantity" invisible="1"/>
                                            <field name="price_unit" invisible="1"/>
                                        </group>
                                        <group>
                                            <field name="total_amount"/>
                                            <field name="tax_ids" widget="many2many_tags"/>
                                            <field name="tax_amount"/>
                                            <field name="payment_mode"/>
                                            <field name="attachment_ids" widget="many2many_binary"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Internal notes..."/>
                        </page>
                        <page string="Refusal Reason" name="refusal_reason" invisible="state != 'refused'">
                            <field name="refusal_reason"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
